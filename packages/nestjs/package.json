{
  "name": "@refpool/nestjs",
  "version": "0.1.0",
  "description": "NestJS integration for refpool: dynamic module, injectable service, multi-tenant connection middleware, and a connection health controller.",
  "license": "MIT",
  "author": "Atul Singh <atulsingh.harsh@gmail.com>",
  "type": "module",
  "sideEffects": false,
  "keywords": [
    "nestjs",
    "pool",
    "resource-pool",
    "reference-counting",
    "multi-tenant",
    "connection-pool",
    "middleware"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/atulsingh-harsh/refpool.git",
    "directory": "packages/nestjs"
  },
  "homepage": "https://github.com/atulsingh-harsh/refpool/tree/main/packages/nestjs#readme",
  "bugs": {
    "url": "https://github.com/atulsingh-harsh/refpool/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@refpool/core": "workspace:*"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0",
    "reflect-metadata": "^0.1.13 || ^0.2.0",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/node": "^22.10.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
