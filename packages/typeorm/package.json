{
  "name": "@refpool/typeorm",
  "version": "0.1.0",
  "description": "Multi-tenant TypeORM DataSource pooling built on @refpool/core's reference-counted, bounded LRU pool.",
  "license": "MIT",
  "author": "Atul Singh <atulsingh.harsh@gmail.com> (https://atulsingh.io)",
  "type": "module",
  "sideEffects": false,
  "keywords": [
    "typeorm",
    "datasource",
    "pool",
    "multi-tenant",
    "connection-pool",
    "refpool"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/expedite-atul/refpool.git",
    "directory": "packages/typeorm"
  },
  "homepage": "https://github.com/expedite-atul/refpool/tree/main/packages/typeorm#readme",
  "bugs": {
    "url": "https://github.com/expedite-atul/refpool/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@refpool/core": "workspace:*"
  },
  "peerDependencies": {
    "typeorm": "^0.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "typeorm": "^0.3.20",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18"
  }
}
