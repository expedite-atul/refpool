{
  "name": "@refpool/pg",
  "version": "0.1.0",
  "description": "Multi-tenant node-postgres (pg) Pool pooling built on @refpool/core's reference-counted, bounded LRU pool.",
  "license": "MIT",
  "author": "Atul Singh <atulsingh.harsh@gmail.com>",
  "type": "module",
  "sideEffects": false,
  "keywords": [
    "pg",
    "node-postgres",
    "postgres",
    "pool",
    "multi-tenant",
    "connection-pool",
    "refpool"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/atulsingh-harsh/refpool.git",
    "directory": "packages/node-postgres"
  },
  "homepage": "https://github.com/atulsingh-harsh/refpool/tree/main/packages/node-postgres#readme",
  "bugs": {
    "url": "https://github.com/atulsingh-harsh/refpool/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@refpool/core": "workspace:*"
  },
  "peerDependencies": {
    "pg": "^8.0.0"
  },
  "peerDependenciesMeta": {
    "pg": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^10.16.0",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "pg": "^8.13.1",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
