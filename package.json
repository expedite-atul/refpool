{
  "name": "refpool-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "A keyed, reference-counted, bounded resource pool. Flagship use case: multi-tenant database connection pooling.",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "pnpm -r --filter \"./packages/*\" typecheck",
    "clean": "pnpm -r exec rm -rf dist",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release:dry-run": "pnpm build && changeset publish --dry-run"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.9",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "license": "MIT",
  "author": "Atul Singh <atulsingh.harsh@gmail.com> (https://atulsingh.io)"
}
